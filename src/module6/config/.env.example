# Direction Module 6 - Environment Variables

# PostgreSQL (Neon Serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/direction?sslmode=require

# OpenAI API (Whisper + Embedding)
OPENAI_API_KEY=sk-xxx

# Google Drive Service Account
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# kotoba-whisper settings
WHISPER_MODEL=kotoba-tech/kotoba-whisper-v2.2
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Processing settings
AUDIO_SAMPLE_RATE=16000
SILENCE_THRESHOLD_SEC=3
MAX_CONCURRENT_JOBS=2
