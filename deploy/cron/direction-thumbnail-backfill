# Direction Module 6 - Nightly thumbnail backfill
#
# 配置先: /etc/cron.d/direction-thumbnail-backfill
# 実行時刻: 毎日 07:00 JST（VPS時刻はJST、ネットワーク安定時間帯）
# タイムアウト: 4時間（wrapper側の `timeout 4h`）
# 1回の処理: --limit 80 動画（retry_failed_thumbnails.py側で制御）
# 排他制御: flock -n で多重起動防止
#
# ログ: /root/nightly-thumb.log（logrotate設定あり）

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
MAILTO=""

0 7 * * * root /usr/bin/flock -n /var/lock/direction-thumb.lock /root/nightly-thumbnail-backfill.sh >> /root/nightly-thumb.log 2>&1
